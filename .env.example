# ─── Database ──────────────────────────────────────────────────────────
# The app auto-detects the driver from the hostname:
#   • *.neon.tech                → Neon's HTTP driver (best for serverless)
#   • *.supabase.co / anything   → postgres.js (standard Postgres wire protocol)
#
# You can switch between providers just by changing this URL — no code change.

# Option A: Neon
# Get from https://neon.tech → your project → Connection string (pooled)
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Option B: Supabase
# Dashboard → Project Settings → Database → Connection string.
# For Vercel / serverless use the *Transaction* pooler URL (port 6543) — the
# app already sets prepare:false so pgbouncer works correctly.
# Example (pooler):
#   DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Example (direct connection, long-running server only):
#   DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres

DATABASE_URL=

# ─── Auth ──────────────────────────────────────────────────────────────
# Any long random string. Used to sign JWT session cookies.
# JWT_SECRET=change-me-to-a-long-random-string
